# Postgres local de la sucursal (local-first). Las tablas del POS viven en el
# esquema "schema_barbosa_v2" (no en public). No agregues ?schema= a las URLs:
# prisma.config.ts y src/lib/db.ts lo aplican solos.
DATABASE_URL="postgresql://postgres:<password>@localhost:5433/barbosa"
# Misma conexión para migraciones de Prisma (sin pooler no hay distinción)
DIRECT_URL="postgresql://postgres:<password>@localhost:5433/barbosa"

# Nube consolidada (Fase 2 — job de sincronización; también origen del
# backfill único de scripts/migrar-usuarios-auth.ts)
# NUBE_DIRECT_URL="postgresql://postgres.<proyecto>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Credenciales del admin que crea el seed (pnpm db:seed). Sin valores por
# defecto: el seed falla si faltan. Rotarlas después con
# scripts/rotar-credenciales.ts o desde /usuarios.
SEED_ADMIN_EMAIL="admin@<dominio>"
SEED_ADMIN_PASSWORD="<mínimo 10 caracteres>"
SEED_ADMIN_PIN="<4 dígitos>"

# Opcional — credenciales que usa la suite E2E (por defecto usa las de dev)
# E2E_ADMIN_EMAIL=""
# E2E_ADMIN_PASSWORD=""
# E2E_ADMIN_PIN=""
