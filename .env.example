# Supabase — Settings → Database
# Nota: las tablas del POS viven en el esquema "schema_barbosa_v2" (no en public).
# No agregues ?schema= a las URLs: prisma.config.ts y src/lib/db.ts lo aplican solos.
# Pooler (pgbouncer, puerto 6543) para la app
DATABASE_URL="postgresql://postgres.<proyecto>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexión directa (puerto 5432) para migraciones de Prisma
DIRECT_URL="postgresql://postgres.<proyecto>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<proyecto>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
# Solo servidor: alta de usuarios vía admin API. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Credenciales del admin que crea el seed (pnpm db:seed). Sin valores por
# defecto: el seed falla si faltan. Rotarlas después con
# scripts/rotar-credenciales.ts o desde /usuarios.
SEED_ADMIN_EMAIL="admin@<dominio>"
SEED_ADMIN_PASSWORD="<mínimo 10 caracteres>"
SEED_ADMIN_PIN="<4 dígitos>"

# Opcional — credenciales que usa la suite E2E (por defecto usa las de dev)
# E2E_ADMIN_EMAIL=""
# E2E_ADMIN_PASSWORD=""
# E2E_ADMIN_PIN=""
